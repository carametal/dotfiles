#!/bin/bash

PLUGIN_DIR="$CONFIG_DIR/plugins"

# Colors (macOS Light Mode system colors)
BAR_COLOR=0xccF2F2F7         # translucent light gray (native menu bar)
ACCENT_COLOR=0xff0066cc      # macOS system blue
TEXT_COLOR=0xff1d1d1f        # macOS label color
SUBTEXT_COLOR=0xff6e6e73     # macOS secondary label
DIM_COLOR=0x663c3c43         # macOS tertiary label
WARN_COLOR=0xffff9500        # macOS system orange
ERROR_COLOR=0xffff3b30       # macOS system red

##### Bar Appearance #####
sketchybar \
  --bar \
    position=top \
    height=28 \
    blur_radius=80 \
    color=$BAR_COLOR \
    border_width=0 \
    shadow=off \
    sticky=on \
    padding_left=12 \
    padding_right=12

##### Default values #####
sketchybar --default \
  updates=when_shown \
  icon.font="SF Pro:Regular:13.0" \
  label.font="SF Pro:Regular:13.0" \
  icon.color=$TEXT_COLOR \
  label.color=$TEXT_COLOR \
  padding_left=4 \
  padding_right=4 \
  label.padding_left=4 \
  label.padding_right=4 \
  icon.padding_left=4 \
  icon.padding_right=4

##### AeroSpace Workspace Indicators #####
sketchybar --add event aerospace_workspace_change

for sid in $(aerospace list-workspaces --all 2>/dev/null); do
  sketchybar --add item space."$sid" left \
    --set space."$sid" \
      background.color=0x22000000 \
      background.corner_radius=4 \
      background.height=18 \
      background.drawing=off \
      label="$sid" \
      label.font="SF Pro:Regular:12.0" \
      label.color=$DIM_COLOR \
      label.padding_left=6 \
      label.padding_right=6 \
      click_script="aerospace workspace $sid" \
      script="$PLUGIN_DIR/aerospace.sh $sid" \
    --subscribe space."$sid" aerospace_workspace_change
done

# Bracket workspaces together with a subtle background
sketchybar --add bracket spaces '/space\..*/' \
  --set spaces \
    background.color=0x11000000 \
    background.corner_radius=6 \
    background.height=22 \
    background.drawing=on \
    padding_left=2 \
    padding_right=2

##### Front App (left, after workspaces) #####
sketchybar --add item front_app left \
  --set front_app \
    icon.drawing=off \
    label.font="SF Pro:Medium:13.0" \
    label.color=$TEXT_COLOR \
    padding_left=8 \
    padding_right=4 \
    script="$PLUGIN_DIR/front_app.sh" \
  --subscribe front_app front_app_switched

##### Right Side Items #####
sketchybar --add item clock right \
  --set clock \
    update_freq=10 \
    icon.drawing=off \
    label.font="SF Pro:Regular:13.0" \
    label.color=$TEXT_COLOR \
    padding_left=4 \
    padding_right=8 \
    script="$PLUGIN_DIR/clock.sh"

sketchybar --add item battery right \
  --set battery \
    update_freq=120 \
    icon.drawing=off \
    label.font="SF Pro:Regular:13.0" \
    padding_left=4 \
    padding_right=4 \
    script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery system_woke power_source_change

sketchybar --add item wifi right \
  --set wifi \
    icon.drawing=off \
    label.font="SF Pro:Regular:13.0" \
    label.color=$SUBTEXT_COLOR \
    padding_left=4 \
    padding_right=4 \
    script="$PLUGIN_DIR/wifi.sh" \
  --subscribe wifi wifi_change

##### Force initial update #####
sketchybar --update
